{
  "name": "cdk-2026",
  "version": "0.1.0",
  "bin": {
    "cdk-2026": "bin/cdk-2026.js",
    "stop-rdb": " aws rds stop-db-cluster --db-cluster-identifier cdk2026stack-auroraclusterxxx-xxxxx",
    "start-rdb": "aws rds start-db-cluster --db-cluster-identifier cdk2026stack-auroraclusterxxx-xxxxx",
    "check-rdb": "aws rds describe-db-clusters --db-cluster-identifier cdk2026stack-auroraclusterxxx-xxxxx  --query \"DBClusters[0].Status\" --output text"
  },
  "scripts": {
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^25.6.0",
    "jest": "^30",
    "ts-jest": "^29",
    "aws-cdk": "2.1119.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.250.0",
    "constructs": "^10.6.0"
  }
}
